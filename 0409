def d(n):
    return n + sum(map(int, str(n)))

generated = [False] * 10001

for n in range(1, 10001):
    value = d(n)
    if value <= 10000:
        generated[value] = True

for n in range(1, 10001):
    if not generated[n]:
        print(n)


