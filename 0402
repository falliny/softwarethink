#####9012번#####
T = int(input())

for _ in range(T):
    s = input()
    stack = []
    ok = True

    for ch in s:
        if ch == '(':
            stack.append(ch)
        else:
            if len(stack) == 0:
                ok = False
                break
            stack.pop()

    if len(stack) == 0 and ok:
        print("YES")
    else:
        print("NO")


