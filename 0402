#####4344번#####
C = int(input())

for _ in range(C):
    N = list(map(int, input().split()))
    people = N[0]
    scores = N[1:]

    avg = sum(scores) / people
    count = 0

    for score in scores:
        if score > avg:
            count += 1

    percent = count / people * 100
    print(f"{percent:.3f}%")


